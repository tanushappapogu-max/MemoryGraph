{
  "name": "memorygraph",
  "version": "1.0.0",
  "description": "Local AI memory graph plugin for Cluely — auto-captures context and injects personalized knowledge into every response",
  "author": "Tanush Appapogu",
  "private": true,
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "dev:full": "tsx scripts/dev.ts --full-capture",
    "next:dev": "next dev --port 3000",
    "daemon": "tsx src/cli.ts start",
    "proxy": "tsx src/proxy/openai-proxy.ts",
    "memorygraph": "tsx src/cli.ts",
    "mcp": "tsx src/mcp/server.ts",
    "demo": "tsx scripts/demo.ts",
    "setup": "prisma generate && prisma db push",
    "build": "next build",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push || tsx prisma/init-db.ts",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^6.8.2",
    "lucide-react": "^0.468.0",
    "next": "^15.0.4",
    "openai": "^4.73.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vis-network": "^10.1.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.0.4",
    "postcss": "^8.4.49",
    "prisma": "^6.8.2",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
